{
  "manifest_version": 3,
  "name": "LinuxDo Side Reader",
  "version": "0.0.23",
  "description": "Open linux.do topics in a right-side slide-out panel without leaving the page",
  "permissions": [],
  "host_permissions": [
    "https://linux.do/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://linux.do/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "LinuxDo Side Reader"
  }
}
