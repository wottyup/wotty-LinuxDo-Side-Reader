{
  "manifest_version": 3,
  "name": "LinuxDo Side Reader",
  "version": "0.0.31",
  "description": "把 linux.do 改成双栏：左半边帖子列表，右半边当前帖子页面",
  "permissions": [],
  "host_permissions": [
    "https://linux.do/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://linux.do/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "LinuxDo Side Reader",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
